# PlatformIO
.pio/
.pioenvs/
.piolibdeps/

# Editor
.vscode/
.idea/

# Generated
*.o
*.elf
*.bin
firmware/ESPMaster/WebAssets.h
firmware/ESPMaster/BuildVersion.h
firmware/ESPMaster/WifiCredentials.h
firmware/Unit/BuildVersion.h
# Belt-and-braces: catch generated BuildVersion.h in any firmware project
# (new or renamed) without needing a .gitignore bump each time.
firmware/*/BuildVersion.h
firmware/*/WebAssets.h
# PlatformIO Arduino preprocessor leaves a transient *.ino.cpp in the
# project root during builds; harmless but trips the dirty check in
# build_version.py's git-rev detection.
*.ino.cpp

# Python
__pycache__/
*.pyc
.pytest_cache/
# Build-time .hex files live under .pio/ which is already ignored. The
# UnitBootloader/prebuilt/ hex is intentionally checked in, so don't
# blanket-ignore *.hex here.
.claude/
flashing/prebuilt/

# PCB design handoff zips (regenerated on demand)
PCB/*.zip
# combined.md is a transient concatenation produced by artifacts/build_docs.py
PCB/MASTER_V2/artifacts/combined.md
