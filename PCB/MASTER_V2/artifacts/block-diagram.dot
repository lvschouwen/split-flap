digraph master_v2_revB {
    rankdir=TB;
    ratio=0.7;
    graph [label="Master v2 Rev B — Logical Connectivity\nESP32-S3 (primary) + ESP32-H2 (radio coprocessor) + TCA9548A I2C mux\n100 × 70 mm, 4-layer, 8 × (16 units) = 128 unit capacity",
           labelloc=t, fontsize=14, fontname="Helvetica-Bold", fontcolor="#222222",
           pad=0.5, nodesep=0.3, ranksep=0.55, splines=true, bgcolor="#ffffff",
           size="13,10"];
    node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
           margin="0.15,0.08"];
    edge  [fontname="Helvetica", fontsize=9, color="#555555"];

    // ───── POWER INPUTS ──────────────────────────────────────────
    subgraph cluster_input {
        label="Power Inputs";
        style="dashed"; color="#888888"; fontsize=11;
        USBC     [label="USB-C (J1)\n5 V, ≤ 1.5 A\nD+/D- to S3 USB", fillcolor="#FFE4B5"];
        JACK     [label="DC jack (J2)\n5.5/2.1 mm\n5 V, ≤ 8 A", fillcolor="#FFE4B5"];
    }

    // ───── PROTECTION + OR-ING ───────────────────────────────────
    subgraph cluster_prot {
        label="Input protection";
        style="dashed"; color="#888888"; fontsize=11;
        FB1  [label="FB1 BLM18PG471\n470 Ω @ 100 MHz"];
        U1   [label="U1 USBLC6-2SC6\nUSB ESD"];
        Q1   [label="Q1 AO3401A\nreverse-polarity\nPMOS"];
        D1   [label="D1 SMAJ5.0CA\nTVS (bidir)"];
        U2   [label="U2 LM66100DCKR\nideal-diode OR\n(USB path only)", fillcolor="#E0F2FF"];
        DBF  [label="D_BACKFEED SS14\nSchottky 1 A", fillcolor="#E0F2FF"];
    }

    // ───── POWER RAILS ───────────────────────────────────────────
    subgraph cluster_rails {
        label="Power rails";
        style="filled"; color="#FFFAE5"; fontsize=11;
        USB5V   [label="USB_5V_IN", shape=ellipse, fillcolor="#FFE4B5"];
        JACK5V  [label="JACK_5V\n(post Q1/D1)\nC_BULK 470 µF", shape=ellipse, fillcolor="#FFD28A"];
        V5LOG   [label="5V_LOGIC\n(buck input)\n32 µF bulk", shape=ellipse, fillcolor="#FFD28A"];
        V5RAIL  [label="5V_RAIL\n(row power)\n267 µF bulk", shape=ellipse, fillcolor="#FFB562"];
        V33     [label="3V3_RAIL\n(logic)\n76 µF bulk", shape=ellipse, fillcolor="#B5E7FF"];
    }

    // ───── BUCK REGULATOR ────────────────────────────────────────
    U4 [label="U4 AP63300WU-7\nsynchronous buck\n3.8–32 V → 3.3 V @ 3 A\n500 kHz\nL_BUCK 4.7 µH + 44 µF out",
        fillcolor="#D3FFD3"];

    // ───── MCUs ──────────────────────────────────────────────────
    S3 [label="U5 ESP32-S3-WROOM-1-N16R8\nprimary MCU\n16 MB flash + 8 MB PSRAM\nWiFi + BT\nPCB antenna (keep-out 15×7 mm)",
        fillcolor="#CDE8FF", shape=box3d];
    H2 [label="U_H2 ESP32-H2-MINI-1-N4\nradio coprocessor\n802.15.4 + BLE 5 + Zigbee/Thread\nPCB antenna (keep-out 11×6 mm)",
        fillcolor="#E8D6FF", shape=box3d];

    // ───── MUX + LEVEL SHIFTERS + ROWS ───────────────────────────
    U6 [label="U6 TCA9548APWR\n8-channel I2C mux\n@ 0x70 (A0..A2 = GND)\n/RESET = S3 IO10",
        fillcolor="#FFE0E0"];

    subgraph cluster_rows {
        label="8 rows × PCA9306 + protection + XH-4";
        style="dashed"; color="#888888"; fontsize=11;
        rank=same;
        ROW1 [label="Row 1\nU7 PCA9306\n+ F1 2A polyfuse\n+ SMBJ5.0A\n+ PESD3V3L5UW\n+ 47 µF + 100 nF\n→ J3 XH-4", fillcolor="#FFF0B3"];
        ROW2 [label="Row 2\n(identical block)", fillcolor="#FFF0B3"];
        ROW3 [label="Row 3", fillcolor="#FFF0B3"];
        ROW4 [label="Row 4", fillcolor="#FFF0B3"];
        ROW5 [label="Row 5", fillcolor="#FFF0B3"];
        ROW6 [label="Row 6", fillcolor="#FFF0B3"];
        ROW7 [label="Row 7", fillcolor="#FFF0B3"];
        ROW8 [label="Row 8\n(identical block)\n→ J10 XH-4", fillcolor="#FFF0B3"];
    }

    // ───── DEBUG ─────────────────────────────────────────────────
    subgraph cluster_dbg {
        label="Debug access";
        style="dashed"; color="#888888"; fontsize=11;
        DBG_S3   [label="JP_DEBUG_S3\n1×4 UART0\n(3V3, GND, TX, RX)", fillcolor="#EEEEEE"];
        DBG_H2   [label="JP_DEBUG_H2\n1×6 UART0 + EN + BOOT_SEL\n(factory flash + console)", fillcolor="#EEEEEE"];
        DBG_I2C  [label="JP_DEBUG_I2C\n1×4 pre-mux\nlogic-analyzer tap", fillcolor="#EEEEEE"];
        TP_USB   [label="TP_H2_USB_D+/-\n1 mm pads\n(H2 built-in USB-JTAG)", fillcolor="#EEEEEE"];
    }

    // ───── POWER EDGES ───────────────────────────────────────────
    USBC  -> FB1     [label="VBUS"];
    FB1   -> USB5V   ;
    USB5V -> U1      [label="ESD",   style=dotted, arrowhead=none];
    USB5V -> U2      ;
    U2    -> V5LOG   [label="OR-ed"];
    JACK  -> Q1      ;
    Q1    -> D1      [style=dotted, arrowhead=none];
    Q1    -> JACK5V  ;
    JACK5V-> V5RAIL  [label="DIRECT\n(no LM66100)", color="#AA0000", fontcolor="#AA0000", penwidth=2];
    JACK5V-> DBF     ;
    DBF   -> V5LOG   [label="backfeed\nanode→cathode"];
    V5LOG -> U4      [label="VIN"];
    U4    -> V33     [label="L_BUCK"];

    // 3V3 distribution
    V33   -> S3      [label="VDD"];
    V33   -> H2      [label="VDD"];
    V33   -> U6      [label="VCC"];
    V33   -> ROW1    [label="VREF1\n+ pullups", style=dashed];

    // 5V_RAIL distribution
    V5RAIL -> ROW1 [label="5 V via F1..F8"];
    V5RAIL -> ROW8 [label="5 V"];

    // ───── USB DATA ──────────────────────────────────────────────
    USBC  -> U1      [label="D+/D−",  style=dashed];
    U1    -> S3      [label="IO19/20\n90 Ω diff"];

    // ───── INTER-MCU UART (5 signals, UART only) ────────────────
    S3 -> H2 [label="IO17 TX → IO4 RX\n921 600 8N1", color="#006400", fontcolor="#006400", penwidth=1.8];
    H2 -> S3 [label="IO5 TX → IO18 RX", color="#006400", fontcolor="#006400", penwidth=1.8];
    S3 -> H2 [label="IO11 → EN\n(H2_RESET_N, 1 kΩ ser)", color="#006400", fontcolor="#006400", style=dashed];
    S3 -> H2 [label="IO13 → IO9\n(H2_BOOT_SEL, 1 kΩ ser)", color="#006400", fontcolor="#006400", style=dashed];
    H2 -> S3 [label="IO10 → IO12\n(H2_IRQ, o-d)", color="#006400", fontcolor="#006400", style=dashed];

    // ───── I2C TREE ──────────────────────────────────────────────
    S3 -> U6 [label="IO8/9 SDA/SCL (3V3)\n4.7 kΩ pullup", color="#8B0000", fontcolor="#8B0000", penwidth=1.6];
    U6 -> ROW1 [label="ch0\nMUX_SDA0/SCL0", color="#8B0000"];
    U6 -> ROW2 [label="ch1", color="#8B0000"];
    U6 -> ROW3 [label="ch2", color="#8B0000"];
    U6 -> ROW4 [label="ch3", color="#8B0000"];
    U6 -> ROW5 [label="ch4", color="#8B0000"];
    U6 -> ROW6 [label="ch5", color="#8B0000"];
    U6 -> ROW7 [label="ch6", color="#8B0000"];
    U6 -> ROW8 [label="ch7", color="#8B0000"];

    // ───── DEBUG WIRES ───────────────────────────────────────────
    S3 -> DBG_S3  [style=dotted, arrowhead=none, label="U0TXD/RXD"];
    S3 -> DBG_I2C [style=dotted, arrowhead=none, label="pre-mux"];
    H2 -> DBG_H2  [style=dotted, arrowhead=none, label="U0TXD/RXD\n+ EN + BOOT_SEL"];
    H2 -> TP_USB  [style=dotted, arrowhead=none, label="IO26/27"];
}
