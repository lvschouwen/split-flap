  (paper "A3")

  (title_block
    (title "Split-Flap Master v2 Rev B - placement mockup")
    (date "2026-04-22")
    (rev "B")
    (company "split-flap")
    (comment 1 "Authoritative netlist: SCHEMATIC.md alongside.")
    (comment 2 "BOM: BOM.csv. Pinout: PINOUT.md. Handoff: README.md.")
    (comment 3 "This file is a PLACEMENT MOCKUP — board outline, antenna keep-outs,")
    (comment 4 "mounting holes, and silkscreen placeholders only. No tracks, no real")
    (comment 5 "footprints, no DRC-clean nets. Layout engineer recaptures from scratch.")
