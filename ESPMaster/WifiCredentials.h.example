// Template for WifiCredentials.h — used when WIFI_USE_DIRECT == true.
//
// Copy this file to WifiCredentials.h (which is gitignored) and fill in
// your SSID / password. The actual WifiCredentials.h is NOT tracked by
// git so your creds never land in a commit.
//
// If you stay in captive-portal mode (WIFI_USE_DIRECT == false) you don't
// need this file at all.
#pragma once

const char* wifiDirectSsid     = "YOUR_SSID";
const char* wifiDirectPassword = "YOUR_PASSWORD";
